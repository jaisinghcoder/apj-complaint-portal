# Server
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
# Include a database name at the end (example: /complaints)
MONGODB_URI=mongodb://127.0.0.1:27017/complaints

# Auth
JWT_SECRET=change_me_in_real_deploy
JWT_EXPIRES_IN=7d

# Optional: admin seeding
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# Optional: allow admin registration via API
ADMIN_REGISTER_SECRET=change_me

# Google OAuth (requires Google Identity client id)
GOOGLE_CLIENT_ID=650386444850-0eou68kd9ls3jnt2qfjruidubaldecp0.apps.googleusercontent.com

# SMTP (for sending password reset emails)
# Example for Gmail (use App Passwords):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM="Your App <no-reply@yourdomain.com>"
# FRONTEND_URL=http://localhost:5173

# Development helpers
# DEBUG_SEND_RESET=true   # return token in /forgot response (dev only)
