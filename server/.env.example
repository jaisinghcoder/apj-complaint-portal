# Server
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
# Include a database name at the end (example: /complaints)
MONGODB_URI=mongodb://127.0.0.1:27017/complaints

# Auth
JWT_SECRET=change_me_in_real_deploy
JWT_EXPIRES_IN=7d

# Optional: admin seeding
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# Optional: allow admin registration via API
ADMIN_REGISTER_SECRET=change_me
