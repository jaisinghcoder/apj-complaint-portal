# Frontend environment variables for local development
# Copy this to .env (or .env.local) and fill values
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Backend API base URL (include protocol and host, no trailing slash)
VITE_API_URL=http://localhost:3000
# Optional: use a specific frontend origin when registering OAuth
VITE_CLIENT_ORIGIN=http://localhost:5173
